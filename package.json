{
  "name": "quantum-gate-console",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive quantum gate console",
  "scripts": {
    "backend": "node backend/server.cjs",
    "build:pages": "npm run build:static",
    "build:static": "node scripts/build-static.cjs",
    "check": "node --check app.js && node --check backend/server.cjs && node --check backend/store.cjs && node --check backend/mail.cjs",
    "import:render-docs": "node scripts/import-chrome-editor-content.cjs --content documents",
    "import:render-tabs": "node scripts/import-chrome-editor-content.cjs --content generated-tabs",
    "serve": "node scripts/serve-local.cjs",
    "sync:content": "node scripts/sync-content-bundle.cjs",
    "test": "node --check app.js && node --check backend/server.cjs && node --check backend/store.cjs && node --check backend/mail.cjs && node scripts/test-quantum-core.cjs && node scripts/test-backend.cjs && node scripts/smoke-generated-tabs.cjs",
    "test:backend": "node scripts/test-backend.cjs",
    "test:editor": "node scripts/smoke-generated-tabs.cjs --editor-open-only",
    "test:entanglement3:repro": "node scripts/repro-entanglement3-bugs.cjs",
    "test:mailbox": "node scripts/smoke-generated-tabs.cjs --mailbox-only",
    "test:pages": "npm run test:static",
    "test:static": "node scripts/build-static.cjs && node scripts/smoke-static-build.cjs",
    "test:smoke": "node scripts/smoke-generated-tabs.cjs"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
