  "tabs": [
    {
      "id": "editor-introduction",
      "label": "Introduction",
      "layout": {
        "items": [
          {
            "id": "text-box-mqfim5js-l",
            "type": "text-box",
            "left": 180,
            "top": 73,
            "width": 676,
            "height": 442,
            "z": 657,
            "text": "Welcome to Qubit Lab, a place where you can experiment with qubits, flipping them, measuring them and entangling them. You can even teleport the state of a qubit from one computer to another (coming soon!), all with no knowledge of quantum mechanics and no pesky math to deal with! The lab itself is still under construction but you can get a preview of coming attractions by going on the tour. This will take you through a series of rooms designed to introduce you to qubits and their bizarre properties. Each room can be accessed through tabs in your browser, and each comes with a Reset button and a What's this? button. We strongly suggest that you click on What's this? to get a demonstration of the functioning of the tab and a brief description of the physics behind it.",
            "buttons": [
              "done"
            ],
            "buttonMode": "done"
          }
        ],
        "gridSnap": true,
        "canvasWidth": 1600,
        "canvasHeight": 760,
        "savedAt": 1781546338603
      }
    },
